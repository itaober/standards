{
  "name": "@itaober/eslint-config",
  "version": "0.1.0-alpha.3",
  "license": "MIT",
  "description": "ESLint preset",
  "author": "Taober <itaober@gmail.com> (https://github.com/itaober)",
  "homepage": "https://github.com/itaober/standards/tree/main/packages/eslint#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/itaober/standards/tree/main/packages/eslint"
  },
  "keywords": [
    "eslint-config"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "clear": "rm -rf dist",
    "build": "pnpm clear && rollup -c"
  },
  "peerDependencies": {
    "eslint": ">=8.4.0"
  },
  "dependencies": {
    "@eslint/compat": "^1.1.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import-x": "^0.5.3",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^15.7.0"
  },
  "devDependencies": {
    "@itaober/tsconfig": "workspace:*",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/eslint": "^8.56.10",
    "@types/node": "^20.14.9",
    "rollup": "^4.18.0"
  }
