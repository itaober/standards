{
  "name": "@itaober/commitlint",
  "version": "0.1.0-alpha.3",
  "license": "MIT",
  "description": "Commontlint preset",
  "author": "Taober <itaober@gmail.com> (https://github.com/itaober)",
  "homepage": "https://github.com/itaober/standards/tree/main/packages/commitlint#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/itaober/standards/tree/main/packages/commitlint"
  },
  "keywords": [
    "commitlint"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "cli.js"
  ],
  "bin": {
    "commitlint": "./node_modules/@commitlint/cli/cli.js",
    "cz": "./node_modules/commitizen/bin/git-cz.js",
    "git-cz": "./node_modules/commitizen/bin/git-cz.js",
    "commitizen": "./node_modules/commitizen/bin/commitizen.js"
  },
  "scripts": {
    "clear": "rm -rf dist",
    "build": "pnpm clear && rollup -c"
  },
  "dependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@commitlint/cz-commitlint": "^19.2.0",
    "@commitlint/types": "^19.0.3",
    "@itaober/tsconfig": "workspace:*",
    "commitizen": "^4.3.0",
    "inquirer": "9"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.6",
    "rollup": "^4.18.0",
    "typescript": "^5.5.2"
  }
}
